# ==========================================
# CẤU HÌNH MÔI TRƯỜNG PRODUCTION (MÁY CHỦ THỰC TẾ)
# ==========================================

# 1. Server Configuration
PORT=5000
NODE_ENV=production

# 2. Database Configuration (Thay đổi user, pass, tên db cho phù hợp)
# Ví dụ MySQL: DATABASE_URL="mysql://root:password@localhost:3306/ankhang_db"
DATABASE_URL="mysql://root:password@localhost:3306/ankhang_db"

# 3. Security (Rất quan trọng)
# Mã bí mật dùng để mã hóa Token đăng nhập. Hãy tạo một chuỗi ngẫu nhiên dài (ví dụ: băm SHA256)
JWT_SECRET="TẠO_MỘT_CHUỖI_BÍ_MẬT_SIÊU_DÀI_Ở_ĐÂY_VÀ_KHÔNG_CHIA_SẺ_CHO_AI"

ADMIN_EMAIL="admin@ankhang.com"
ADMIN_PASSWORD="THAY_BANG_MAT_KHAU_MANH"

# 4. Client URL (CORS)
# Tên miền chính thức của website, dùng để chặn các trang web khác gọi trộm API
CLIENT_URL="https://ankhanggroup.vn"
CLIENT_URLS="https://ankhang-real-estate.vercel.app,https://ankhanggroup.vn"

# 5. Upload storage
# Render production: mount a Persistent Disk and set UPLOAD_ROOT to its uploads directory.
# Example Render disk mount path: /var/data
UPLOAD_ROOT="/var/data/uploads"

# ==========================================
# LƯU Ý KHI TRIỂN KHAI (DÀNH CHO FRONTEND - Vite)
# Trong thư mục gốc, tạo thêm file .env.production cho Frontend:
# VITE_API_URL="https://api.ankhanggroup.vn/api"
# ==========================================
